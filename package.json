{
  "name": "org.vechain.sync2",
  "version": "2.5.0",
  "description": "VeChain Sync2",
  "productName": "Sync2",
  "cordovaId": "org.vechain.sync2",
  "capacitorId": "",
  "author": "VeChain Community",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "build:pwa": "quasar build -m pwa",
    "build:electron": "quasar build -m electron",
    "build:electron:mac": "quasar build -m electron -T darwin",
    "lint": "eslint .",
    "typecheck": "quasar prepare && tsc --noEmit",
    "test": "TS_NODE_PROJECT=test/tsconfig.json node -r ts-node/register/transpile-only test/run.ts",
    "test:coverage": "nyc npm test",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@ledgerhq/hw-transport-node-hid-noevents": "^6.35.2",
    "electron-context-menu": "^4.1.2",
    "electron-updater": "^6.8.3",
    "node-hid": "^3.3.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@ledgerhq/hw-transport-webhid": "^6.35.2",
    "@quasar/app-webpack": "^4.4.5",
    "@quasar/extras": "^1.18.0",
    "@types/color": "^4.2.1",
    "@types/ledgerhq__hw-transport": "^4.21.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vechain/connex-driver": "^2.3.2",
    "@vechain/connex-framework": "^2.3.2",
    "@vechain/hw-app-vet": "^0.2.0",
    "@vechain/picasso": "^2.0.1",
    "@vue/compiler-sfc": "^3.5.34",
    "asmcrypto.js": "^2.3.2",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "bignumber.js": "^11.1.1",
    "buffer": "^6.0.3",
    "color": "^5.0.3",
    "crypto-browserify": "^3.12.1",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-debug": "^4.1.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "https-browserify": "^1.0.0",
    "more-entropy": "0.0.7",
    "nyc": "^18.0.0",
    "postcss": "^8.5.15",
    "process": "^0.11.10",
    "qr-scanner": "^1.2.0",
    "qrcode-svg": "^1.1.0",
    "quasar": "^2.19.3",
    "register-service-worker": "^1.7.2",
    "sass": "^1.99.0",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "thor-devkit": "^2.2.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "url": "^0.11.4",
    "validator-ts": "^0.9.1",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0",
    "vue-gtag": "^3.7.1",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.3.1",
    "workbox-webpack-plugin": "^7.4.1",
    "worker-loader": "^3.0.8"
  },
  "engines": {
    "node": ">=22.12 <29",
    "npm": ">=10",
    "yarn": ">= 1.21.1"
  },
  "nyc": {
    "all": true,
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.d.ts"
    ],
    "reporter": [
      "text",
      "json-summary",
      "lcov"
    ],
    "check-coverage": true,
    "lines": 100,
    "statements": 100,
    "functions": 100,
    "branches": 100
  },
  "browserslist": [
    "last 10 Chrome versions",
    "last 10 Firefox versions",
    "last 4 Edge versions",
    "last 7 Safari versions",
    "last 8 Android versions",
    "last 8 ChromeAndroid versions",
    "last 8 FirefoxAndroid versions",
    "last 10 iOS versions",
    "last 5 Opera versions"
  ],
  "overrides": {
    "cipher-base": "1.0.7",
    "electron-updater": {
      "js-yaml": "4.1.1"
    },
    "ethers": {
      "ws": "8.20.1"
    },
    "node-hid": {
      "tar-fs": "2.1.4"
    },
    "pbkdf2": "3.1.5",
    "sha.js": "2.4.12"
  }
